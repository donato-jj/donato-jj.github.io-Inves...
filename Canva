  <script type="module">
    /* =========================================================
      Single-file App: Vanilla JS (ES Module)
      - Sin frameworks
      - Sin build tools
      - No innerHTML con datos crudos
      - Búsqueda global con ranking + debounce + resaltado seguro
      - Filtros + orden + chips + modal + tabla sortable + timeline + tabs + accordion
      - Dark/light persistente + reduced motion
      - Formulario robusto con honeypot + validación + mailto
      ========================================================= */

    // ---------- Utils ----------
    const Utils = (() => {
      function el(tag, attrs = {}, children = []) {
        const node = document.createElement(tag);
        for (const [k, v] of Object.entries(attrs)) {
          if (v === null || v === undefined) continue;
          if (k === "className") node.className = v;
          else if (k.startsWith("aria-") || k === "role" || k === "tabIndex" || k.startsWith("data-") || k === "type" || k === "href" || k === "id") {
            node.setAttribute(k, String(v));
          } else {
            node[k] = v;
          }
        }
        for (const c of children) node.appendChild(c);
        return node;
      }
      function clear(node) { node.replaceChildren(); }
      function debounce(fn, ms) {
        let t = null;
        return (...args) => {
          if (t) clearTimeout(t);
          t = setTimeout(() => fn(...args), ms);
        };
      }
      function sanitizeText(input) {
        return String(input ?? "").replace(/\u0000/g, "").trim();
      }
      function formatDate(iso) {
        const s = String(iso || "").trim();
        if (!/^\d{4}-\d{2}-\d{2}$/.test(s)) return s || "—";
        const [y, m, d] = s.split("-").map(Number);
        return new Date(Date.UTC(y, m - 1, d)).toLocaleDateString("es-AR", { year: "numeric", month: "short", day: "2-digit" });
      }
      function groupBy(items, keyFn) {
        const m = new Map();
        for (const it of items) {
          const k = keyFn(it);
          if (!m.has(k)) m.set(k, []);
          m.get(k).push(it);
        }
        return m;
      }
      function uniqueTagsFromProjects(projects) {
        const set = new Set();
        for (const p of projects) for (const t of (p.tags || [])) set.add(t);
        return Array.from(set).sort((a, b) => a.localeCompare(b, "es"));
      }
      function prefersReducedMotion() {
        return window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      }
      function normalize(s) {
        return String(s || "")
          .toLowerCase()
          .normalize("NFD")
          .replace(/\p{Diacritic}/gu, "");
      }
      function highlightTextToFragment(text, query) {
        const frag = document.createDocumentFragment();
        const raw = sanitizeText(text);
        const q = normalize(query);
        if (!q) { frag.appendChild(document.createTextNode(raw)); return frag; }
        const terms = q.split(/\s+/).filter(Boolean);
        if (terms.length === 0) { frag.appendChild(document.createTextNode(raw)); return frag; }

        let i = 0;
        const lower = normalize(raw);
        while (i < raw.length) {
          let best = null;
          for (const t of terms) {
            const idx = lower.indexOf(t, i);
            if (idx !== -1 && (best === null || idx < best.idx)) best = { idx, term: t };
          }
          if (!best) { frag.appendChild(document.createTextNode(raw.slice(i))); break; }
          if (best.idx > i) frag.appendChild(document.createTextNode(raw.slice(i, best.idx)));
          const end = best.idx + best.term.length;
          const mark = document.createElement("mark");
          mark.textContent = raw.slice(best.idx, end);
          frag.appendChild(mark);
          i = end;
        }
        return frag;
      }
      function trapFocus(container) {
        const focusable = () => Array.from(container.querySelectorAll([
          "a[href]", "button:not([disabled])", "input:not([disabled])",
          "select:not([disabled])", "textarea:not([disabled])", "[tabindex]:not([tabindex='-1'])"
        ].join(","))).filter(el => el.offsetParent !== null);

        function onKeyDown(e) {
          if (e.key !== "Tab") return;
          const items = focusable();
          if (items.length === 0) return;
          const first = items[0];
          const last = items[items.length - 1];
          if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
          else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
        }

        container.addEventListener("keydown", onKeyDown);
        const obs = new MutationObserver(() => {
          if (container.hidden) {
            container.removeEventListener("keydown", onKeyDown);
            obs.disconnect();
          }
        });
        obs.observe(container, { attributes: true, attributeFilter: ["hidden"] });
      }
      function setActiveNav(sectionId) {
        document.querySelectorAll(".nav-link").forEach((a) => {
          const target = (a.getAttribute("href") || "").replace("#", "");
          if (target === sectionId) a.setAttribute("aria-current", "page");
          else a.removeAttribute("aria-current");
        });
      }
      function initNav() {
        const toggle = document.querySelector(".nav-toggle");
        const menu = document.getElementById("navMenu");
        if (!toggle || !menu) return;

        const close = () => { menu.dataset.open = "false"; toggle.setAttribute("aria-expanded", "false"); };

        toggle.addEventListener("click", () => {
          const open = menu.dataset.open === "true";
          menu.dataset.open = String(!open);
          toggle.setAttribute("aria-expanded", String(!open));
        });

        menu.addEventListener("click", (e) => { if (e.target.closest("a")) close(); });

        document.addEventListener("click", (e) => {
          if (menu.dataset.open !== "true") return;
          const inside = e.target.closest("#navMenu") || e.target.closest(".nav-toggle");
          if (!inside) close();
        });

        window.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
      }

      return {
        el, clear, debounce, sanitizeText, formatDate, groupBy, uniqueTagsFromProjects,
        prefersReducedMotion, normalize, highlightTextToFragment, trapFocus, setActiveNav, initNav
      };
    })();

    // ---------- State ----------
    const State = (() => {
      const state = {
        status: { dataLoaded: false, error: null },
        data: null,
        filters: { area: "all", status: "all", tags: new Set() },
        sort: "updated_desc",
        pubFilters: { type: "all", topic: "all", query: "" },
        pubSort: "year_desc",
        timelineView: "full"
      };
      const listeners = new Set();
      function subscribe(fn) { listeners.add(fn); return () => listeners.delete(fn); }
      function setState(patch) {
        const prev = snapshot(state);
        merge(state, patch);
        for (const fn of listeners) fn(state, prev);
      }
      function merge(target, patch) {
        for (const [k, v] of Object.entries(patch)) {
          if (v && typeof v === "object" && !Array.isArray(v) && !(v instanceof Set)) {
            if (!target[k] || typeof target[k] !== "object") target[k] = {};
            merge(target[k], v);
          } else target[k] = v;
        }
      }
      function snapshot(obj) {
        return JSON.parse(JSON.stringify(obj, (key, value) => (value instanceof Set ? Array.from(value) : value)));
      }
      return { state, setState, subscribe };
    })();

    // ---------- Data loader (from embedded JSON) ----------
    const Data = (() => {
      function readJson(id) {
        const node = document.getElementById(id);
        if (!node) throw new Error(`Falta el script JSON: ${id}`);
        return JSON.parse(node.textContent);
      }
      function loadAll() {
        const projects = readJson("projectsData");
        const publications = readJson("publicationsData");
        const topics = readJson("topicsData");
        const timeline = readJson("timelineData");
        return { projects, publications, topics, timeline };
      }
      return { loadAll };
    })();

    // ---------- Filters & sorts ----------
    const Filters = (() => {
      function applyProjectFiltersAndSort(projects, filters, sort) {
        const tagUniverse = Utils.uniqueTagsFromProjects(projects);
        let items = [...projects];

        if (filters.area !== "all") items = items.filter((p) => p.area === filters.area);
        if (filters.status !== "all") items = items.filter((p) => p.status === filters.status);

        const selectedTags = filters.tags || new Set();
        if (selectedTags.size > 0) {
          items = items.filter((p) => {
            const set = new Set(p.tags || []);
            for (const t of selectedTags) if (!set.has(t)) return false;
            return true;
          });
        }

        items = sortProjects(items, sort);
        return { items, tagUniverse };
      }

      function applyPublicationFiltersAndSort(publications, pubFilters, pubSort) {
        let items = [...publications];

        if (pubFilters.type !== "all") items = items.filter((p) => p.type === pubFilters.type);
        if (pubFilters.topic !== "all") items = items.filter((p) => (p.topic_tags || []).includes(pubFilters.topic));

        const q = (pubFilters.query || "").trim().toLowerCase();
        if (q) {
          items = items.filter((p) => {
            const hay = [p.title, (p.authors || []).join(" "), (p.topic_tags || []).join(" "), p.abstract, p.reference_note].join(" ").toLowerCase();
            return hay.includes(q);
          });
        }

        items = sortPublications(items, pubSort);
        return { items };
      }

      function sortProjects(items, sort) {
        const out = [...items];
        if (sort === "alpha") { out.sort((a, b) => a.title.localeCompare(b.title, "es")); return out; }
        if (sort === "score") { out.sort((a, b) => (scoreProject(b) - scoreProject(a))); return out; }
        out.sort((a, b) => String(b.updated_at).localeCompare(String(a.updated_at)));
        return out;
      }

      function scoreProject(p) {
        const tags = (p.tags || []).length;
        const rec = Number(String(p.updated_at || "0000-00-00").replaceAll("-", ""));
        return tags * 10 + (rec / 1000000);
      }

      function sortPublications(items, sort) {
        const out = [...items];
        if (sort === "alpha") { out.sort((a, b) => a.title.localeCompare(b.title, "es")); return out; }
        out.sort((a, b) => (b.year || -1) - (a.year || -1));
        return out;
      }

      function fillSelect(select, pairs) {
        Utils.clear(select);
        for (const [value, label] of pairs) {
          select.appendChild(Utils.el("option", { value }, [document.createTextNode(label)]));
        }
      }

      function initControls() {
        initResearchControls();
        initPublicationControls();
      }

      function initResearchControls() {
        const areaSel = document.getElementById("filterArea");
        const statusSel = document.getElementById("filterStatus");
        const tagsMount = document.getElementById("filterTags");
        const sortSel = document.getElementById("sortProjects");
        const clearBtn = document.getElementById("clearFilters");
        if (!areaSel || !statusSel || !tagsMount || !sortSel || !clearBtn) return;

        fillSelect(areaSel, [
          ["all", "Todas"],
          ["Evolución", "Evolución"],
          ["Bioética", "Bioética"],
          ["Métodos", "Métodos"],
          ["Filosofía", "Filosofía"]
        ]);
        fillSelect(statusSel, [["all", "Todos"], ["active", "Activos"], ["completed", "Completados"]]);
        fillSelect(sortSel, [["updated_desc", "Actualización (desc)"], ["score", "Relevancia (simple)"], ["alpha", "Alfabético (A→Z)"]]);

        areaSel.addEventListener("change", () => State.setState({ filters: { ...State.state.filters, area: areaSel.value } }));
        statusSel.addEventListener("change", () => State.setState({ filters: { ...State.state.filters, status: statusSel.value } }));
        sortSel.addEventListener("change", () => State.setState({ sort: sortSel.value }));

        tagsMount.addEventListener("click", (e) => {
          const chip = e.target.closest("button[data-tag]");
          if (!chip) return;
          const tag = chip.getAttribute("data-tag");
          if (!tag) return;
          const next = new Set(State.state.filters.tags);
          if (next.has(tag)) next.delete(tag); else next.add(tag);
          State.setState({ filters: { ...State.state.filters, tags: next } });
        });

        tagsMount.addEventListener("keydown", (e) => {
          if (e.key !== "Enter" && e.key !== " ") return;
          const chip = e.target.closest("button[data-tag]");
          if (!chip) return;
          e.preventDefault();
          chip.click();
        });

        clearBtn.addEventListener("click", () => {
          State.setState({ filters: { area: "all", status: "all", tags: new Set() }, sort: "updated_desc" });
          areaSel.value = "all"; statusSel.value = "all"; sortSel.value = "updated_desc";
        });
      }

      function initPublicationControls() {
        const typeSel = document.getElementById("filterPubType");
        const topicSel = document.getElementById("filterPubTopic");
        const search = document.getElementById("pubSearch");
        const sortSel = document.getElementById("sortPubs");
        const clearBtn = document.getElementById("clearPubFilters");
        if (!typeSel || !topicSel || !search || !sortSel || !clearBtn) return;

        fillSelect(typeSel, [["all","Todos"], ["book","Libro"], ["article","Artículo"], ["essay","Ensayo"], ["guideline","Guía"]]);
        fillSelect(topicSel, [["all","Todos"]]);
        fillSelect(sortSel, [["year_desc","Año (desc)"], ["alpha","Alfabético (A→Z)"]]);

        typeSel.addEventListener("change", () => State.setState({ pubFilters: { ...State.state.pubFilters, type: typeSel.value } }));
        topicSel.addEventListener("change", () => State.setState({ pubFilters: { ...State.state.pubFilters, topic: topicSel.value } }));
        search.addEventListener("input", () => State.setState({ pubFilters: { ...State.state.pubFilters, query: search.value } }));
        sortSel.addEventListener("change", () => State.setState({ pubSort: sortSel.value }));

        clearBtn.addEventListener("click", () => {
          State.setState({ pubFilters: { type: "all", topic: "all", query: "" }, pubSort: "year_desc" });
          typeSel.value = "all"; topicSel.value = "all"; search.value = ""; sortSel.value = "year_desc";
        });
      }

      return { applyProjectFiltersAndSort, applyPublicationFiltersAndSort, initControls, fillSelect };
    })();

    // ---------- Table ----------
    const Table = (() => {
      let tableSort = { key: "area", dir: "asc" };

      function buildAreasTableModel(projects) {
        const grouped = Utils.groupBy(projects, (p) => p.area);
        const rows = [];
        for (const [area, items] of grouped.entries()) {
          const active = items.filter(p => p.status === "active").length;
          const completed = items.filter(p => p.status === "completed").length;
          const updated = items.map(p => p.updated_at).sort().slice(-1)[0] || "0000-00-00";
          rows.push({ area, active, completed, updated });
        }
        return { rows };
      }

      function init() {
        const table = document.getElementById("areasTable");
        const filter = document.getElementById("areasTableFilter");
        const announce = document.getElementById("areasTableAnnounce");
        if (!table || !filter || !announce) return;

        const head = table.querySelector("thead");
        head?.addEventListener("click", (e) => {
          const th = e.target.closest("th[data-sort]");
          if (!th) return;
          sortBy(th.getAttribute("data-sort"));
        });

        head?.addEventListener("keydown", (e) => {
          if (e.key !== "Enter" && e.key !== " ") return;
          const th = e.target.closest("th[data-sort]");
          if (!th) return;
          e.preventDefault();
          sortBy(th.getAttribute("data-sort"));
        });

        filter.addEventListener("input", () => renderFiltered());

        function sortBy(key) {
          if (!key) return;
          if (tableSort.key === key) tableSort.dir = tableSort.dir === "asc" ? "desc" : "asc";
          else { tableSort.key = key; tableSort.dir = "asc"; }
          announce.textContent = `Orden: ${key} (${tableSort.dir}).`;
          renderFiltered();
        }

        function sortRows(rows) {
          const { key, dir } = tableSort;
          const mult = dir === "asc" ? 1 : -1;
          const out = [...rows];
          out.sort((a, b) => {
            const av = a[key], bv = b[key];
            if (key === "area") return mult * String(av).localeCompare(String(bv), "es");
            if (key === "updated") return mult * String(av).localeCompare(String(bv));
            return mult * (Number(av) - Number(bv));
          });
          return out;
        }

        function renderFiltered() {
          if (!State.state.data?.projects) return;
          const model = buildAreasTableModel(State.state.data.projects);
          const q = filter.value.trim().toLowerCase();
          let rows = model.rows;
          if (q) rows = rows.filter(r => r.area.toLowerCase().includes(q));
          rows = sortRows(rows);

          const tbody = table.querySelector("tbody");
          if (!tbody) return;
          Utils.clear(tbody);
          for (const r of rows) {
            const tr = document.createElement("tr");
            const td1 = document.createElement("td"); td1.textContent = r.area;
            const td2 = document.createElement("td"); td2.textContent = String(r.active);
            const td3 = document.createElement("td"); td3.textContent = String(r.completed);
            const td4 = document.createElement("td"); td4.textContent = Utils.formatDate(r.updated);
            tr.append(td1, td2, td3, td4);
            tbody.appendChild(tr);
          }
        }
      }

      return { init, buildAreasTableModel };
    })();

    // ---------- Timeline ----------
    const Timeline = (() => {
      function initTabs() {
        const full = document.getElementById("timelineTabFull");
        const periods = document.getElementById("timelineTabPeriods");
        if (!full || !periods) return;

        function setSelected(view) {
          const isFull = view === "full";
          full.setAttribute("aria-selected", String(isFull));
          periods.setAttribute("aria-selected", String(!isFull));
          full.tabIndex = isFull ? 0 : -1;
          periods.tabIndex = !isFull ? 0 : -1;
        }

        full.addEventListener("click", () => { State.setState({ timelineView: "full" }); setSelected("full"); });
        periods.addEventListener("click", () => { State.setState({ timelineView: "periods" }); setSelected("periods"); });

        setSelected(State.state.timelineView);
      }

      function render(mount, timeline, view) {
        Utils.clear(mount);
        const items = [...timeline].sort((a, b) => String(a.year).localeCompare(String(b.year)));
        const out = view === "periods" ? groupByPeriod(items) : items;

        for (const it of out) {
          const li = Utils.el("li", { className: "timeline-item", tabIndex: 0 }, [
            Utils.el("div", { className: "year" }, [document.createTextNode(String(it.year))]),
            Utils.el("div", {}, [document.createTextNode(it.event_title)]),
            Utils.el("div", {}, [document.createTextNode(it.event_description)]),
            Utils.el("div", { className: "sig" }, [document.createTextNode(`Importancia: ${it.significance}`)])
          ]);
          mount.appendChild(li);
        }
      }

      function groupByPeriod(items) {
        const buckets = [
          { label: "Antes de 1830", min: -Infinity, max: 1829 },
          { label: "1830–1859", min: 1830, max: 1859 },
          { label: "1860–1900", min: 1860, max: 1900 },
          { label: "1901+", min: 1901, max: Infinity }
        ];
        const grouped = [];
        for (const b of buckets) {
          const pick = items.filter((it) => yearToNumber(it.year) >= b.min && yearToNumber(it.year) <= b.max);
          if (pick.length === 0) continue;
          grouped.push({
            year: b.label,
            event_title: `${pick.length} hito(s)`,
            event_description: pick.map(p => `${p.year}: ${p.event_title}`).slice(0, 6).join(" · ") + (pick.length > 6 ? " …" : ""),
            significance: "Vista resumida por períodos (para lectura rápida)."
          });
        }
        return grouped;
      }

      function yearToNumber(y) {
        const s = String(y);
        const m = s.match(/\d{4}/);
        return m ? Number(m[0]) : 0;
      }

      return { initTabs, render };
    })();

    // ---------- Theme ----------
    const Theme = (() => {
      function init() {
        const btn = document.getElementById("themeToggle");
        if (!btn) return;
        const getTheme = () => document.documentElement.dataset.theme || "light";
        const setTheme = (t) => {
          document.documentElement.dataset.theme = t;
          try { localStorage.setItem("iic_theme", t); } catch {}
        };
        btn.addEventListener("click", () => setTheme(getTheme() === "dark" ? "light" : "dark"));
      }
      return { init };
    })();

    // ---------- Router ----------
    const Router = (() => {
      function init() {
        function onHashChange() {
          const id = (location.hash || "#home").replace("#", "");
          const el = document.getElementById(id);
          if (!el) return;
          Utils.setActiveNav(id);
          el.scrollIntoView({ behavior: Utils.prefersReducedMotion() ? "auto" : "smooth", block: "start" });
          const main = document.getElementById("main");
          if (main) main.focus({ preventScroll: true });
        }
        window.addEventListener("hashchange", onHashChange);
        Utils.setActiveNav((location.hash || "#home").replace("#", ""));
      }
      return { init };
    })();

    // ---------- Search ----------
    const Search = (() => {
      function initDrawer() {
        const openBtn = document.getElementById("openSearch");
        const drawer = document.getElementById("searchDrawer");
        const input = document.getElementById("searchInput");
        const results = document.getElementById("searchResults");
        const meta = document.getElementById("searchMeta");
        if (!openBtn || !drawer || !input || !results || !meta) return;

        const close = () => {
          drawer.hidden = true;
          document.body.style.overflow = "";
          openBtn.focus();
        };
        const open = () => {
          drawer.hidden = false;
          document.body.style.overflow = "hidden";
          input.value = "";
          Utils.clear(results);
          meta.textContent = "Escribí para buscar…";
          input.focus();
          Utils.trapFocus(drawer);
        };

        openBtn.addEventListener("click", open);
        drawer.addEventListener("click", (e) => { if (e.target.closest("[data-close-drawer]")) close(); });
        window.addEventListener("keydown", (e) => { if (!drawer.hidden && e.key === "Escape") close(); });

        const run = Utils.debounce(() => {
          const q = Utils.sanitizeText(input.value).trim();
          if (!q) {
            meta.textContent = "Escribí para buscar…";
            Utils.clear(results);
            return;
          }
          const hits = globalSearch(State.state.data, q);
          meta.textContent = `${hits.length} resultado(s) para “${q}”.`;

          Utils.clear(results);
          if (hits.length === 0) {
            results.appendChild(Utils.el("li", {}, [
              Utils.el("strong", {}, [document.createTextNode("Sin resultados")]),
              Utils.el("div", { className: "where" }, [document.createTextNode("Probá sin acentos o con términos más generales.")])
            ]));
            return;
          }

          for (const h of hits.slice(0, 30)) {
            const li = Utils.el("li", {}, [
              Utils.el("strong", {}, [document.createTextNode(h.title)]),
              Utils.el("div", { className: "where" }, [document.createTextNode(h.where)]),
              Utils.el("div", {}, [Utils.highlightTextToFragment(h.snippet, q)])
            ]);
            results.appendChild(li);
          }
        }, 300);

        input.addEventListener("input", run);
      }

      function globalSearch(data, query) {
        if (!data) return [];
        const q = Utils.normalize(query);
        const terms = q.split(/\s+/).filter(Boolean);
        const results = [];
        const push = (obj) => results.push(obj);

        for (const p of data.projects) {
          const hay = [
            p.title, p.area, p.summary, (p.tags || []).join(" "),
            (p.methods || []).join(" "), p.collaboration,
            (p.content?.sections || []).map(s => `${s.title} ${s.text}`).join(" ")
          ].join(" ");
          const score = scoreDoc({ title: p.title, tags: p.tags, body: hay }, terms);
          if (score > 0) push({ score, title: p.title, where: `Proyecto · ${p.area}`, snippet: snippetFrom(hay, query) });
        }

        for (const p of data.publications) {
          const hay = [p.title, p.type, String(p.year || ""), (p.authors || []).join(" "), (p.topic_tags || []).join(" "), p.abstract, p.reference_note].join(" ");
          const score = scoreDoc({ title: p.title, tags: p.topic_tags, body: hay }, terms);
          if (score > 0) push({ score, title: p.title, where: `Publicación · ${p.type}`, snippet: snippetFrom(hay, query) });
        }

        for (const t of data.topics) {
          const hay = [t.label, t.description, (t.related || []).join(" ")].join(" ");
          const score = scoreDoc({ title: t.label, tags: t.related, body: hay }, terms);
          if (score > 0) push({ score, title: t.label, where: `Tema · ${t.key}`, snippet: snippetFrom(hay, query) });
        }

        return results.sort((a, b) => b.score - a.score);
      }

      function scoreDoc({ title, tags, body }, terms) {
        const nt = Utils.normalize(title);
        const nbody = Utils.normalize(body);
        const nTags = Utils.normalize((tags || []).join(" "));
        let score = 0;
        for (const term of terms) {
          const exactTitle = nt === term;
          const titleHit = nt.includes(term);
          const tagHit = nTags.includes(term);
          const bodyHit = nbody.includes(term);
          if (exactTitle) score += 30;
          else if (titleHit) score += 18;
          else if (tagHit) score += 10;
          else if (bodyHit) score += 4;
        }
        return score;
      }

      function snippetFrom(text, query) {
        const clean = Utils.sanitizeText(text);
        const idx = Utils.normalize(clean).indexOf(Utils.normalize(query));
        if (idx === -1) return clean.slice(0, 180) + (clean.length > 180 ? "…" : "");
        const start = Math.max(0, idx - 60);
        const end = Math.min(clean.length, idx + 120);
        const prefix = start > 0 ? "…" : "";
        const suffix = end < clean.length ? "…" : "";
        return prefix + clean.slice(start, end) + suffix;
      }

      return { initDrawer };
    })();

    // ---------- Form ----------
    const Form = (() => {
      function init() {
        const form = document.getElementById("contactForm");
        const status = document.getElementById("formStatus");
        const resetBtn = document.getElementById("contactReset");
        if (!form || !status || !resetBtn) return;

        resetBtn.addEventListener("click", () => {
          form.reset();
          status.textContent = "";
          clearErrors(form);
        });

        form.addEventListener("submit", (e) => {
          e.preventDefault();
          status.textContent = "";
          clearErrors(form);

          const fd = new FormData(form);
          const hp = String(fd.get("company") || "");
          if (hp.trim() !== "") {
            status.textContent = "Envío bloqueado (anti-spam).";
            return;
          }

          const name = Utils.sanitizeText(fd.get("name"));
          const email = Utils.sanitizeText(fd.get("email"));
          const reason = Utils.sanitizeText(fd.get("reason"));
          const message = Utils.sanitizeText(fd.get("message"));

          const errors = validate({ name, email, reason, message });
          if (Object.keys(errors).length) {
            showErrors(form, errors);
            status.textContent = "Revisá los campos marcados.";
            return;
          }

          const subject = `Contacto — ${reason}`;
          const body = [
            "Mensaje preparado desde el sitio institucional:",
            "",
            `Nombre: ${name}`,
            `Email: ${email}`,
            `Motivo: ${reason}`,
            "",
            message,
            "",
            "—",
            "Nota: Este mensaje se preparó sin backend (front-only)."
          ].join("\n");

          status.replaceChildren(
            document.createTextNode("Mensaje preparado. "),
            makeMailtoLink("contacto@example.org", subject, body),
            document.createTextNode(" (abre tu cliente de correo).")
          );
        });
      }

      function validate({ name, email, reason, message }) {
        const errors = {};
        if (!name || name.trim().length < 2) errors.name = "Ingresá un nombre (mín. 2 caracteres).";
        if (!email || !isValidEmail(email)) errors.email = "Ingresá un email válido.";
        if (!reason) errors.reason = "Seleccioná un motivo.";
        if (!message || message.trim().length < 40) errors.message = "El mensaje debe tener al menos 40 caracteres (contexto + objetivo).";
        return errors;
      }

      function isValidEmail(email) { return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email); }

      function showErrors(form, errors) {
        for (const [k, msg] of Object.entries(errors)) {
          const slot = form.querySelector(`[data-error-for="${k}"]`);
          if (slot) slot.textContent = msg;
        }
      }
      function clearErrors(form) { form.querySelectorAll(".error").forEach((e) => e.textContent = ""); }

      function makeMailtoLink(to, subject, body) {
        const a = document.createElement("a");
        a.href = `mailto:${encodeURIComponent(to)}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        a.textContent = "Abrir mailto";
        a.className = "btn btn-ghost";
        return a;
      }

      return { init };
    })();

    // ---------- Render ----------
    const Render = (() => {
      function renderAll() {
        const { data } = State.state;
        if (!data) return;

        renderAreasGrid(data.projects);
        renderLatestPublications(data.publications);

        renderProjects(data.projects, State.state.filters, State.state.sort);
        renderPublications(data.publications, data.topics, State.state.pubFilters, State.state.pubSort);

        renderMythsAccordion();
        renderTimeline(data.timeline, State.state.timelineView);

        populateTopicsSelect(data.topics);
      }

      function renderAreasGrid(projects) {
        const mount = document.getElementById("areasGrid");
        if (!mount) return;
        const grouped = Utils.groupBy(projects, (p) => p.area);
        Utils.clear(mount);

        for (const [area, items] of grouped.entries()) {
          const active = items.filter((p) => p.status === "active").length;
          const completed = items.filter((p) => p.status === "completed").length;
          const last = items.map((p) => p.updated_at).sort().slice(-1)[0];

          const card = Utils.el("article", { className: "card" }, [
            Utils.el("h3", {}, [document.createTextNode(area)]),
            Utils.el("p", { className: "meta" }, [document.createTextNode(`Activos: ${active} · Completados: ${completed}`)]),
            Utils.el("p", { className: "muted" }, [document.createTextNode(`Última actualización: ${Utils.formatDate(last)}`)]),
            Utils.el("div", { className: "card-actions" }, [
              Utils.el("a", { className: "btn btn-ghost", href: "#research" }, [document.createTextNode("Ver proyectos")])
            ])
          ]);
          mount.appendChild(card);
        }
      }

      function renderLatestPublications(publications) {
        const mount = document.getElementById("latestPublications");
        if (!mount) return;
        const sorted = [...publications].sort((a, b) => (b.year || 0) - (a.year || 0));
        const top = sorted.slice(0, 6);
        Utils.clear(mount);

        for (const p of top) {
          const li = Utils.el("li", {}, [
            Utils.el("strong", {}, [document.createTextNode(p.title)]),
            document.createTextNode(" — "),
            Utils.el("span", { className: "muted" }, [document.createTextNode(`${prettyPubType(p.type)}${p.year ? ` · ${p.year}` : ""}`)])
          ]);
          mount.appendChild(li);
        }
      }

      function renderProjects(projects, filters, sort) {
        const grid = document.getElementById("projectsGrid");
        const meta = document.getElementById("projectsMeta");
        if (!grid || !meta) return;

        const { items, tagUniverse } = Filters.applyProjectFiltersAndSort(projects, filters, sort);
        syncTagChips(tagUniverse);

        meta.textContent = `${items.length} proyecto(s) visibles — filtros combinables (área/estado/etiquetas).`;
        Utils.clear(grid);

        if (items.length === 0) {
          grid.appendChild(Utils.el("div", { className: "card" }, [
            Utils.el("h3", {}, [document.createTextNode("Sin resultados")]),
            Utils.el("p", { className: "muted" }, [document.createTextNode("Probá limpiar filtros o ajustar etiquetas.")])
          ]));
          return;
        }

        for (const p of items) {
          const tags = Utils.el("div", { className: "chips", "aria-label": "Etiquetas del proyecto" }, [
            ...(p.tags || []).slice(0, 6).map((t) => Utils.el("span", { className: "chip", role: "note" }, [document.createTextNode(t)]))
          ]);

          const card = Utils.el("article", { className: "card" }, [
            Utils.el("h3", {}, [document.createTextNode(p.title)]),
            Utils.el("p", { className: "meta" }, [document.createTextNode(`${p.area} · ${prettyStatus(p.status)} · Actualizado: ${Utils.formatDate(p.updated_at)}`)]),
            Utils.el("p", {}, [document.createTextNode(p.summary)]),
            tags,
            Utils.el("div", { className: "card-actions" }, [
              Utils.el("button", { className: "btn btn-primary", type: "button", "data-open-project": p.id }, [document.createTextNode("Ver detalle")]),
              Utils.el("button", { className: "btn btn-ghost", type: "button", "data-add-tag": (p.tags && p.tags[0]) ? p.tags[0] : "" }, [document.createTextNode("Filtrar similar")])
            ])
          ]);
          grid.appendChild(card);
        }

        // Delegation (bind once)
        if (!grid.dataset.bound) {
          grid.addEventListener("click", onProjectsClick, { passive: true });
          grid.dataset.bound = "true";
        }

        // Areas table baseline render (then Table module handles sort/filter)
        const table = document.getElementById("areasTable");
        if (table) {
          const model = Table.buildAreasTableModel(projects);
          renderAreasTable(model);
        }
      }

      function onProjectsClick(e) {
        const btn = e.target.closest("button");
        if (!btn) return;

        const openId = btn.getAttribute("data-open-project");
        if (openId) {
          const p = State.state.data.projects.find((x) => x.id === openId);
          if (p) openProjectModal(p);
          return;
        }

        const addTag = btn.getAttribute("data-add-tag");
        if (addTag) {
          const next = new Set(State.state.filters.tags);
          next.add(addTag);
          State.setState({ filters: { ...State.state.filters, tags: next } });
        }
      }

      function openProjectModal(project) {
        const modal = document.getElementById("modal");
        const body = document.getElementById("modalBody");
        const title = document.getElementById("modalTitle");
        if (!modal || !body || !title) return;

        title.textContent = project.title;
        Utils.clear(body);

        body.appendChild(Utils.el("p", { className: "muted" }, [
          document.createTextNode(`${project.area} · ${prettyStatus(project.status)} · Actualizado: ${Utils.formatDate(project.updated_at)}`)
        ]));

        body.appendChild(Utils.el("h3", {}, [document.createTextNode("Resumen")]));
        body.appendChild(Utils.el("p", {}, [document.createTextNode(project.summary)]));

        body.appendChild(Utils.el("h3", {}, [document.createTextNode("Métodos (descripción general)")]));
        body.appendChild(Utils.el("ul", { className: "bullets" }, (project.methods || []).map((m) => Utils.el("li", {}, [document.createTextNode(m)]))));

        body.appendChild(Utils.el("h3", {}, [document.createTextNode("Colaboración")]));
        body.appendChild(Utils.el("p", {}, [document.createTextNode(project.collaboration)]));

        body.appendChild(Utils.el("h3", {}, [document.createTextNode("Detalle")]));
        for (const section of (project.content?.sections || [])) {
          body.appendChild(Utils.el("h4", {}, [document.createTextNode(section.title)]));
          body.appendChild(Utils.el("p", {}, [document.createTextNode(section.text)]));
        }

        modal.hidden = false;
        document.body.style.overflow = "hidden";
        const closeBtn = modal.querySelector("[data-close-modal]");
        if (closeBtn) closeBtn.focus();
        Utils.trapFocus(modal);

        const clickClose = (e) => {
          const isClose = e.target && (e.target.matches("[data-close-modal]") || e.target.matches(".modal-overlay"));
          if (isClose) closeModal();
        };
        modal.addEventListener("click", clickClose, { once: true });

        function onKey(ev) {
          if (ev.key === "Escape") {
            closeModal();
            window.removeEventListener("keydown", onKey);
          }
        }
        window.addEventListener("keydown", onKey);
      }

      function closeModal() {
        const modal = document.getElementById("modal");
        if (!modal) return;
        modal.hidden = true;
        document.body.style.overflow = "";
      }

      function renderMythsAccordion() {
        const mount = document.getElementById("mythsAccordion");
        if (!mount) return;
        const items = [
          { q: "“La evolución es solo una opinión”", a: "En ciencia, “teoría” refiere a un marco explicativo robusto respaldado por evidencia y abierto a revisión. No es sinónimo de “opinión personal”." },
          { q: "“Selección natural significa que gana el más fuerte”", a: "El desempeño depende del ambiente y del rasgo. A veces favorece eficiencia reproductiva, otras resistencia a enfermedad, otras cooperación, etc." },
          { q: "“No hay fósiles de transición, por eso es falso”", a: "El registro fósil es incompleto por procesos geológicos. Aun así, existen series y hallazgos que conectan linajes. La interpretación requiere prudencia y contexto." },
          { q: "“La evolución tiene un objetivo o dirección predeterminada”", a: "La evolución no implica una meta fija. Describe cambios poblacionales a lo largo del tiempo bajo presiones y restricciones, con contingencia histórica." }
        ];

        Utils.clear(mount);
        for (const [i, it] of items.entries()) {
          const buttonId = `acc-btn-${i}`;
          const panelId = `acc-panel-${i}`;

          const btn = Utils.el("button", {
            className: "accordion-button",
            id: buttonId,
            type: "button",
            "aria-expanded": "false",
            "aria-controls": panelId
          }, [
            document.createTextNode(it.q),
            Utils.el("span", { className: "muted", "aria-hidden": "true" }, [document.createTextNode("+")])
          ]);

          const panel = Utils.el("div", {
            className: "accordion-panel",
            id: panelId,
            role: "region",
            "aria-labelledby": buttonId,
            hidden: true
          }, [Utils.el("p", {}, [document.createTextNode(it.a)])]);

          const wrap = Utils.el("div", { className: "accordion-item" }, [btn, panel]);
          mount.appendChild(wrap);

          btn.addEventListener("click", () => {
            const expanded = btn.getAttribute("aria-expanded") === "true";
            btn.setAttribute("aria-expanded", String(!expanded));
            panel.hidden = expanded;
            const sign = btn.querySelector("span[aria-hidden]");
            if (sign) sign.replaceChildren(document.createTextNode(expanded ? "+" : "–"));
          });
        }
      }

      function renderTimeline(timeline, view) {
        const mount = document.getElementById("timeline");
        if (!mount) return;
        Timeline.render(mount, timeline, view);
      }

      function renderPublications(publications, topics, pubFilters, pubSort) {
        const grid = document.getElementById("pubsGrid");
        const meta = document.getElementById("pubsMeta");
        if (!grid || !meta) return;

        const { items } = Filters.applyPublicationFiltersAndSort(publications, pubFilters, pubSort);
        meta.textContent = `${items.length} recurso(s) visibles — “referencias sugeridas” (verificar edición antes de citar).`;
        Utils.clear(grid);

        if (items.length === 0) {
          grid.appendChild(Utils.el("div", { className: "card" }, [
            Utils.el("h3", {}, [document.createTextNode("Sin resultados")]),
            Utils.el("p", { className: "muted" }, [document.createTextNode("Probá ajustar tipo/tema/búsqueda o limpiar filtros.")])
          ]));
          return;
        }

        for (const p of items) {
          const authors = (p.authors || []).join(", ");
          const year = p.year ? String(p.year) : "s/f (referencia general)";
          const tags = Utils.el("div", { className: "chips", "aria-label": "Etiquetas temáticas" }, [
            ...(p.topic_tags || []).slice(0, 6).map((t) => Utils.el("span", { className: "chip", role: "note" }, [document.createTextNode(t)]))
          ]);

          const card = Utils.el("article", { className: "card" }, [
            Utils.el("h3", {}, [document.createTextNode(p.title)]),
            Utils.el("p", { className: "meta" }, [document.createTextNode(`${prettyPubType(p.type)} · ${year}${authors ? ` · ${authors}` : ""}`)]),
            Utils.el("p", {}, [document.createTextNode(p.abstract)]),
            tags,
            Utils.el("p", { className: "muted" }, [document.createTextNode(p.reference_note)])
          ]);
          grid.appendChild(card);
        }
      }

      function renderAreasTable(model) {
        const table = document.getElementById("areasTable");
        if (!table) return;
        const tbody = table.querySelector("tbody");
        if (!tbody) return;
        Utils.clear(tbody);
        for (const row of model.rows) {
          const tr = Utils.el("tr", {}, [
            Utils.el("td", {}, [document.createTextNode(row.area)]),
            Utils.el("td", {}, [document.createTextNode(String(row.active))]),
            Utils.el("td", {}, [document.createTextNode(String(row.completed))]),
            Utils.el("td", {}, [document.createTextNode(Utils.formatDate(row.updated))])
          ]);
          tbody.appendChild(tr);
        }
      }

      function syncTagChips(tagUniverse) {
        const mount = document.getElementById("filterTags");
        if (!mount) return;
        const current = mount.getAttribute("data-tags") || "";
        const next = tagUniverse.join("|");
        if (current === next) {
          // still update pressed state
          for (const btn of mount.querySelectorAll("button[data-tag]")) {
            const tag = btn.getAttribute("data-tag");
            btn.setAttribute("aria-pressed", String(State.state.filters.tags.has(tag)));
          }
          return;
        }

        mount.setAttribute("data-tags", next);
        Utils.clear(mount);

        for (const tag of tagUniverse) {
          const pressed = State.state.filters.tags.has(tag);
          const chip = Utils.el("button", { className: "chip", type: "button", "aria-pressed": String(pressed), "data-tag": tag }, [
            document.createTextNode(tag)
          ]);
          mount.appendChild(chip);
        }
      }

      function populateTopicsSelect(topics) {
        const topicSel = document.getElementById("filterPubTopic");
        if (!topicSel) return;
        if (topicSel.dataset.ready === "true") return;

        const options = [["all","Todos"], ...topics.map(t => [t.label, t.label])];
        Filters.fillSelect(topicSel, options);
        topicSel.value = State.state.pubFilters.topic;
        topicSel.dataset.ready = "true";
      }

      function prettyStatus(s) { return s === "active" ? "Activo" : "Completado"; }
      function prettyPubType(t) { return ({ book: "Libro", article: "Artículo", essay: "Ensayo", guideline: "Guía" }[t] || "Recurso"); }

      return { renderAll };
    })();

    // ---------- Init Search Drawer ----------
    function initSearchDrawer() { Search.initDrawer(); }

    // ---------- Init Timeline Tabs ----------
    function initTimelineTabs() { Timeline.initTabs(); }

    // ---------- Init Theme ----------
    function initTheme() { Theme.init(); }

    // ---------- Init Router ----------
    function initRouter() { Router.init(); }

    // ---------- Init nav/menu ----------
    function initNav() { Utils.initNav(); }

    // ---------- Drawer + Modal close handlers (global) ----------
    function initGlobalDismiss() {
      const modal = document.getElementById("modal");
      if (modal && !modal.dataset.bound) {
        modal.addEventListener("click", (e) => {
          const isClose = e.target && (e.target.matches("[data-close-modal]") || e.target.matches(".modal-overlay"));
          if (isClose) {
            modal.hidden = true;
            document.body.style.overflow = "";
          }
        });
        modal.dataset.bound = "true";
      }
    }

    // ---------- Bootstrap ----------
    function bootstrap() {
      initTheme();
      initNav();
      initRouter();
      initSearchDrawer();
      Filters.initControls();
      Table.init();
      initTimelineTabs();
      Form.init();
      initGlobalDismiss();

      const y = document.getElementById("year");
      if (y) y.textContent = String(new Date().getFullYear());

      try {
        const data = Data.loadAll();
        State.setState({ data, status: { ...State.state.status, dataLoaded: true } });
      } catch (err) {
        console.error(err);
        State.setState({ status: { ...State.state.status, dataLoaded: false, error: "No se pudo cargar el contenido JSON." } });
      }

      // Re-render on relevant updates
      State.subscribe((next, prev) => {
        const dataChanged = next.data !== prev.data;
        const filtersChanged = next.filters !== prev.filters || next.sort !== prev.sort;
        const pubsChanged = next.pubFilters !== prev.pubFilters || next.pubSort !== prev.pubSort;
        const timelineChanged = next.timelineView !== prev.timelineView;
        if (dataChanged || filtersChanged || pubsChanged || timelineChanged) Render.renderAll();
      });

      // First render
      Render.renderAll();
    }

    bootstrap();
  </script>
</body>
